<Window x:Class="TCSLogTool.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TCS Log Tool"
        Height="600"
        Width="1100">
    <DockPanel>
        <DockPanel DockPanel.Dock="Top" LastChildFill="False" Background="#F0F0F0">

            <DockPanel.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Margin" Value="10,0,0,0"/>
                </Style>
                <Style TargetType="Button">
                    <Setter Property="Margin" Value="5"/>
                    <Setter Property="Padding" Value="10,2"/>
                </Style>
            </DockPanel.Resources>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Content="Open Log" Command="{Binding OpenFileCommand}"/>

                <TextBlock Text="Files:"/>
                <TextBlock Text="{Binding Statistics.FileCount}" Margin="5,0"/>

                <TextBlock Text="Commands:"/>
                <TextBlock Text="{Binding Statistics.CommandCount}" Margin="5,0"/>

                <TextBlock Text="Devices:"/>
                <TextBlock Text="{Binding Statistics.DeviceCount}" Margin="5,0"/>

                <TextBlock Text="Start Time:"/>
                <TextBlock Text="{Binding Statistics.StartTime}" Margin="5,0"/>

                <TextBlock Text="End Time:"/>
                <TextBlock Text="{Binding Statistics.EndTime}" Margin="5,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="Export JSON" Command="{Binding ExportJsonCommand}"/>
                <Button Content="Open Viewer" Command="{Binding OpenViewerCommand}" Margin="5,5,20,5"/>
            </StackPanel>
        </DockPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0" ItemsSource="{Binding Commands}" AutoGenerateColumns="True"/>
            <DataGrid Grid.Row="1" ItemsSource="{Binding States}" AutoGenerateColumns="True"/>
            <DataGrid Grid.Row="2" ItemsSource="{Binding AttributeSeries}" AutoGenerateColumns="True"/>
            <DataGrid Grid.Row="3" ItemsSource="{Binding AttributePoints}" AutoGenerateColumns="True"/>
            <DataGrid Grid.Row="4" ItemsSource="{Binding Logs}" AutoGenerateColumns="True"/>
        </Grid>
    </DockPanel>
</Window>