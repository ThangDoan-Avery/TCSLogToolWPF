<Window x:Class="TCSLogTool.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TCS Log Tool"
        Height="600"
        Width="900">

    <DockPanel>

        <Button DockPanel.Dock="Top"
                Content="Open Log"
                Command="{Binding OpenFileCommand}" />

        <DataGrid ItemsSource="{Binding Logs}"
                  AutoGenerateColumns="True"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" />
                <RowDefinition Height="2*" />
                <RowDefinition Height="2*" />
                <RowDefinition Height="2*" />
            </Grid.RowDefinitions>

            <!-- Commands -->
            <DataGrid Grid.Row="0"
              ItemsSource="{Binding Commands}"
              AutoGenerateColumns="True"/>

            <!-- States -->
            <DataGrid Grid.Row="1"
              ItemsSource="{Binding States}"
              AutoGenerateColumns="True"/>

            <!-- Attributes -->
            <DataGrid Grid.Row="2"
              ItemsSource="{Binding AttributeSeries}"
              AutoGenerateColumns="True"/>

            <!-- AttributesPoint -->
            <DataGrid Grid.Row="2"
              ItemsSource="{Binding AttributePoints}"
              AutoGenerateColumns="True"/>

        </Grid>
    </DockPanel>

</Window>