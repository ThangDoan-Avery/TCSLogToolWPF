<Window x:Class="TCSLogTool.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TCS Log Tool"
        Height="600"
        Width="900">

    <DockPanel>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
            <Button Content="Open Log"
                    Command="{Binding OpenFileCommand}"
                    Margin="5"/>

            <TextBlock Text="Files:" Margin="10,0,0,0"/>
            <TextBlock Text="{Binding Statistics.FileCount}" Margin="5,0"/>

            <TextBlock Text="Commands:" Margin="10,0,0,0"/>
            <TextBlock Text="{Binding Statistics.CommandCount}" Margin="5,0"/>

            <TextBlock Text="Devices:" Margin="10,0,0,0"/>
            <TextBlock Text="{Binding Statistics.DeviceCount}" Margin="5,0"/>

            <TextBlock Text="Start Time:" Margin="10,0,0,0"/>
            <TextBlock Text="{Binding Statistics.StartTime}" Margin="5,0"/>

            <TextBlock Text="End Time:" Margin="10,0,0,0"/>
            <TextBlock Text="{Binding Statistics.EndTime}" Margin="5,0"/>
        </StackPanel>

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="2*" />
                <RowDefinition Height="2*" />
                <RowDefinition Height="2*" />
                <RowDefinition Height="2*" />
                <RowDefinition Height="2*" />
            </Grid.RowDefinitions>

            <DataGrid  Grid.Row="4"
                    ItemsSource="{Binding Logs}"
                    AutoGenerateColumns="True"/>


            <DataGrid Grid.Row="0"
                    ItemsSource="{Binding Commands}"
                    AutoGenerateColumns="True"/>

            <DataGrid Grid.Row="1"
                    ItemsSource="{Binding States}"
                    AutoGenerateColumns="True"/>

            <DataGrid Grid.Row="2"
                    ItemsSource="{Binding AttributeSeries}"
                    AutoGenerateColumns="True"/>

            <DataGrid Grid.Row="3"
                    ItemsSource="{Binding AttributePoints}"
                    AutoGenerateColumns="True"/>

        </Grid>
    </DockPanel>

</Window>