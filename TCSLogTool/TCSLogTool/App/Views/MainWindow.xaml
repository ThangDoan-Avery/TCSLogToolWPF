<Window x:Class="TCSLogTool.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="TCS Log Tool"
        Height="600"
        Width="1100">

    <Window.Resources>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

    </Window.Resources>
    <DockPanel>
        <DockPanel DockPanel.Dock="Top" Background="#F5F5F5" Margin="0,0,0,5">

            <StackPanel>

                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="0">
                        <Button Content="Open Log"
                            Command="{Binding OpenFileCommand}"
                            Margin="0,0,15,0"/>

                        <TextBlock Text="Files:" Margin="5,0"/>
                        <TextBlock Text="{Binding Statistics.FileCount}" Margin="5,0"/>

                        <TextBlock Text="Commands:" Margin="10,0,0,0"/>
                        <TextBlock Text="{Binding Statistics.CommandCount}" Margin="5,0"/>

                        <TextBlock Text="Devices:" Margin="10,0,0,0"/>
                        <TextBlock Text="{Binding Statistics.DeviceCount}" Margin="5,0"/>

                        <!--<TextBlock Text="Start:" Margin="10,0,0,0"/>
                        <TextBlock Text="{Binding Statistics.StartTime}" Margin="5,0"/>

                        <TextBlock Text="End:" Margin="10,0,0,0"/>
                        <TextBlock Text="{Binding Statistics.EndTime}" Margin="5,0"/>-->
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Grid.Column="1">

                        <GroupBox Header="Device Command Log">
                            <StackPanel>
                                <Button Content="Export JSON"
                            Command="{Binding ExportJsonCommand}"/>
                                <Button Content="Open Viewer"
                            Command="{Binding OpenViewerCommand}"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Command Duration Analysis">
                            <StackPanel>
                                <Button Content="Export JSON"
                            Command="{Binding ExportCommandDurationJsonFile}"/>
                                <Button Content="Open Viewer"
                            Command="{Binding OpenCommandDurationLogViewer}"/>
                            </StackPanel>
                        </GroupBox>

                    </StackPanel>
                </Grid>

                <Border Background="#FFFFFF"
                    Margin="10,0,10,10"
                    Padding="10"
                    CornerRadius="5">

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <TextBlock Text="Time Filter"
                           FontWeight="Bold"
                           Margin="0,0,15,0"
                           VerticalAlignment="Center"/>

                        <xctk:DateTimePicker
                            Value="{Binding FilterStart, UpdateSourceTrigger=PropertyChanged}"
                            Format="Custom"
                            FormatString="yyyy-MM-dd HH:mm:ss.fff"
                            Width="200"
                            Margin="5"/>

                        <TextBlock Text=":" VerticalAlignment="Center"/>

                        <xctk:DateTimePicker
                            Value="{Binding FilterEnd, UpdateSourceTrigger=PropertyChanged}"
                            Format="Custom"
                            FormatString="yyyy-MM-dd HH:mm:ss.fff"
                            Width="200"
                            Margin="5"/>

                        <Button Content="Apply Filter"
                            Command="{Binding ApplyFilterCommand}"
                            Margin="10,20,0,0"
                            VerticalAlignment="Center"
                            Padding="10,5"/>

                    </StackPanel>
                </Border>

            </StackPanel>

        </DockPanel>
        <Grid>
            <!--<Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>-->

            <!--<DataGrid Grid.Row="0" ItemsSource="{Binding Commands}" AutoGenerateColumns="True"/>
            <DataGrid Grid.Row="1" ItemsSource="{Binding States}" AutoGenerateColumns="True"/>
            <DataGrid Grid.Row="2" ItemsSource="{Binding AttributeSeries}" AutoGenerateColumns="True"/>
            <DataGrid Grid.Row="3" ItemsSource="{Binding AttributePoints}" AutoGenerateColumns="True"/>
            <DataGrid Grid.Row="4" ItemsSource="{Binding Logs}" AutoGenerateColumns="True"/>-->

            <DataGrid ItemsSource="{Binding Logs}" AutoGenerateColumns="True"/>
        </Grid>
    </DockPanel>
    
</Window>